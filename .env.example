# ===== 抓取模式 =====
# mock = 使用模拟数据（默认，无需浏览器）；playwright = 真实浏览器抓取
SCRAPER=mock

# ===== 数据库 =====
DATABASE_URL="file:./data/app.db"

# ===== 酒店名称 =====
HOTEL_NAME=成都托尼洛兰博基尼酒店

# ===== 定时抓取（cron 表达式，默认每 6 小时一次）=====
SCRAPE_CRON=0 */6 * * *

# ===== 真实后台抓取（SCRAPER=playwright 时生效）=====
# 登录后能看到本店「点评管理」的真实后台 URL；{hotelId} 会被替换为对应酒店 ID。
# 这些默认值多为登录入口占位，请用 npm run capture 探测后改成真实点评页地址。
CTRIP_REVIEW_URL=
CTRIP_HOTEL_ID=
FLIGGY_REVIEW_URL=
FLIGGY_HOTEL_ID=
QUNAR_REVIEW_URL=
QUNAR_HOTEL_ID=
# 抓取时是否显示浏览器窗口（调试用，默认 headless）
SCRAPER_HEADLESS=false

# ===== 邮件通知（SMTP）=====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# 差评告警接收邮箱
ALERT_EMAIL_TO=
