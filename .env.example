# ===== 抓取模式 =====
# mock = 使用模拟数据（默认，无需浏览器）；playwright = 真实浏览器抓取
SCRAPER=mock

# ===== 数据库 =====
DATABASE_URL="file:./data/app.db"

# ===== 酒店名称 =====
HOTEL_NAME=成都托尼洛兰博基尼酒店

# ===== 定时抓取（cron 表达式，默认每 6 小时一次）=====
SCRAPE_CRON=0 */6 * * *

# ===== 邮件通知（SMTP）=====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# 差评告警接收邮箱
ALERT_EMAIL_TO=
